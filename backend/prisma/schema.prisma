generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [uuid_ossp(map: "uuid-ossp")]
}

model User {
  id                         String                    @id @default(uuid()) @db.Uuid
  email                      String                    @unique
  password_hash              String?
  full_name                  String?
  phone                      String?
  address                    String?
  role                       Role                      @default(USER)
  status                     AccountStatus             @default(ACTIVE)
  is_deleted                 Boolean                   @default(false)
  auth_provider              AuthProvider              @default(LOCAL)
  provider_id                String?
  rating_avg                 Float?
  avatar_url                 String?
  bio                        String?
  cccd_back                  String?
  cccd_front                 String?
  cccd_number                String?                   @unique
  created_at                 DateTime                  @default(now())
  kyc_status                 ApprovalStatus?
  updated_at                 DateTime                  @default(now()) @updatedAt
  is_verified                Boolean                  @default(false)
  bank_detail                BankDetail?
  booking_groups             BookingGroup[]
  booking_payout_allocations BookingPayoutAllocation[]
  owned_bookings             Booking[]                 @relation("OwnerRelation")
  rented_bookings            Booking[]                 @relation("RenterRelation")
  cart                       Cart?
  conversations_as_owner     Conversation[]            @relation("OwnerConv")
  conversations_as_renter    Conversation[]            @relation("RenterConv")
  disputes_reported          Dispute[]
  lens_listings              LensListing[]
  sent_messages              Message[]                 @relation("MessageSender")
  notifications              Notification[]
  payouts_as_owner           Payout[]                  @relation("OwnerPayouts")
  payouts_processed_as_admin Payout[]                  @relation("AdminProcessedPayouts")
  created_promotions         Promotion[]               @relation("PromotionCreator")
  reviews_received           Review[]                  @relation("ReviewedUser")
  reviews_written            Review[]                  @relation("Reviewer")
  transactions               Transaction[]
  wallet                     Wallet?
  owner_applications         OwnerApplication[]

  @@map("users")
}

model OwnerApplication {
  id               String          @id @default(uuid()) @db.Uuid
  user_id          String          @db.Uuid
  phone            String
  area             String
  equipment_types  String
  description      String?
  status           ApprovalStatus  @default(PENDING)
  admin_note       String?
  reviewed_at      DateTime?
  created_at       DateTime        @default(now())
  updated_at       DateTime        @updatedAt
  user             User            @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, status])
  @@map("owner_applications")
}

model BankDetail {
  id           String  @id @default(uuid()) @db.Uuid
  user_id      String  @unique @db.Uuid
  bank_name    String?
  bank_account String?
  bank_owner   String?
  user         User    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("bank_details")
}

model Cart {
  id      String     @id @default(uuid()) @db.Uuid
  user_id String     @unique @db.Uuid
  items   CartItem[]
  user    User       @relation(fields: [user_id], references: [id])

  @@map("carts")
}

model CartItem {
  id         String      @id @default(uuid()) @db.Uuid
  cart_id    String      @db.Uuid
  lens_id    String      @db.Uuid
  quantity   Int         @default(1)
  start_date DateTime    @db.Date
  end_date   DateTime    @db.Date
  cart       Cart        @relation(fields: [cart_id], references: [id])
  lens       LensListing @relation(fields: [lens_id], references: [id])

  @@map("cart_items")
}

model Category {
  id            String        @id @default(uuid()) @db.Uuid
  name          String        @unique
  description   String?
  created_at    DateTime      @default(now()) @db.Timestamp(6)
  lens_listings LensListing[]

  @@map("categories")
}

model LensListing {
  id                      String         @id @default(uuid()) @db.Uuid
  owner_id                String         @db.Uuid
  title                   String
  description             String?
  quantity                Int            @default(1)
  brand                   String?
  category_id             String?        @db.Uuid
  approval_status         ApprovalStatus @default(PENDING)
  city                    String?
  district                String?
  ward                    String?
  price_per_day           Decimal        @db.Decimal(12, 2)
  thumbnail               String?
  rating_avg              Float?
  review_count            Int            @default(0)
  available               Boolean        @default(true)
  is_deleted              Boolean        @default(false)
  allowed_deposit_types   DepositType[]  @default([MONEY_PLATFORM])
  required_deposit_amount Decimal?       @db.Decimal(12, 2)
  created_at              DateTime       @default(now()) @db.Timestamp(6)
  market_value            Decimal?       @db.Decimal(12, 2)
  blocked_dates           BlockedDate[]
  booking_items           BookingItem[]
  cart_items              CartItem[]
  images                  LensImage[]
  category                Category?      @relation(fields: [category_id], references: [id])
  owner                   User           @relation(fields: [owner_id], references: [id])
  specs                   LensSpec?
  reviews                 Review[]
  promotions              Promotion[]    @relation("LensToPromotion")

  @@index([owner_id])
  @@index([category_id])
  @@index([brand])
  @@index([city, district])
  @@index([approval_status, available, is_deleted])
  @@map("lens_listings")
}

model LensSpec {
  id                  String      @id @default(uuid()) @db.Uuid
  lens_id             String      @unique @db.Uuid
  focal_length        String?
  max_aperture        String?
  mount               String?
  sensor_format       String?
  image_stabilization Boolean?
  lens                LensListing @relation(fields: [lens_id], references: [id], onDelete: Cascade)

  @@map("lens_specs")
}

model LensImage {
  id        String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lens_id   String      @db.Uuid
  image_url String?
  lens      LensListing @relation(fields: [lens_id], references: [id], onDelete: Cascade)

  @@map("lens_images")
}

model BookingGroup {
  id                     String              @id @default(uuid()) @db.Uuid
  user_id                String              @db.Uuid
  sub_total              Decimal             @db.Decimal(12, 2)
  discount_amount        Decimal             @default(0) @db.Decimal(12, 2)
  total_amount           Decimal             @db.Decimal(12, 2)
  payment_method         PaymentMethod       @default(CASH)
  status                 BookingGroupStatus  @default(PENDING)
  gateway_transaction_id String?
  promotion_id           String?             @db.Uuid
  created_at             DateTime            @default(now())
  updated_at             DateTime            @updatedAt
  promotion              Promotion?          @relation(fields: [promotion_id], references: [id])
  user                   User                @relation(fields: [user_id], references: [id])
  bookings               Booking[]
  transactions           Transaction[]
  wallet_transactions    WalletTransaction[]

  @@index([gateway_transaction_id])
  @@map("booking_groups")
}

model Booking {
  id                        String                   @id @default(uuid()) @db.Uuid
  user_id                   String                   @db.Uuid
  owner_id                  String                   @db.Uuid
  promotion_id              String?                  @db.Uuid
  booking_group_id          String?                  @db.Uuid
  start_date                DateTime
  end_date                  DateTime
  sub_total                 Decimal                  @db.Decimal(12, 2)
  discount_amount           Decimal                  @default(0) @db.Decimal(12, 2)
  total_price               Decimal                  @db.Decimal(12, 2)
  platform_fee_amount       Decimal                  @default(0) @db.Decimal(12, 2)
  status                    BookingStatus            @default(PENDING)
  delivery_method           DeliveryMethod           @default(SELF_PICKUP)
  delivery_address          String?
  is_extension_requested    Boolean                  @default(false)
  requested_end_date        DateTime?
  extension_status          ExtensionStatus?
  created_at                DateTime                 @default(now()) @db.Timestamp(6)
  updated_at                DateTime                 @default(now()) @updatedAt
  selected_deposit_type     DepositType
  deposit_amount            Decimal?                 @db.Decimal(12, 2)
  deposit_note              String?
  items                     BookingItem[]
  booking_payout_allocation BookingPayoutAllocation?
  booking_group             BookingGroup?            @relation(fields: [booking_group_id], references: [id])
  owner                     User                     @relation("OwnerRelation", fields: [owner_id], references: [id])
  promotion                 Promotion?               @relation(fields: [promotion_id], references: [id])
  user                      User                     @relation("RenterRelation", fields: [user_id], references: [id])
  disputes                  Dispute[]
  reviews                   Review[]
  transactions              Transaction[]
  wallet_transactions       WalletTransaction[]
  renter_returned           Boolean                  @default(false)
  handoverReport           HandoverReport?

  @@index([start_date, end_date])
  @@index([status])
  @@index([user_id])
  @@index([owner_id])
  @@index([booking_group_id])
  @@map("bookings")
}

model BookingItem {
  id            String      @id @default(uuid()) @db.Uuid
  booking_id    String      @db.Uuid
  lens_id       String      @db.Uuid
  quantity      Int         @default(1)
  price_per_day Decimal     @db.Decimal(12, 2)
  booking       Booking     @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  lens          LensListing @relation(fields: [lens_id], references: [id])

  @@map("booking_items")
}

model HandoverReport {
  id         String   @id @default(uuid()) @db.Uuid 
  booking_id String   @unique @db.Uuid              
  booking    Booking  @relation(fields: [booking_id], references: [id])
  
  // Dữ liệu lúc Giao máy 
  note_checkin    String?
  images_checkin  String[] 
  signature_a     String?  
  signature_b     String?  
  
  // Dữ liệu lúc Nhận lại máy 
  note_checkout   String?
  images_checkout String[]
  is_damaged      Boolean  @default(false) 
  
  created_at      DateTime @default(now()) @db.Timestamp(6)

  @@map("handover_report") 
}

model Dispute {
  id              String        @id @default(uuid()) @db.Uuid
  booking_id      String        @db.Uuid
  reporter_id     String        @db.Uuid
  reason          String
  evidence_images String[]
  status          DisputeStatus @default(PENDING)
  admin_note      String?
  created_at      DateTime      @default(now()) @db.Timestamp(6)
  updated_at      DateTime      @updatedAt
  booking         Booking       @relation(fields: [booking_id], references: [id])
  reporter        User          @relation(fields: [reporter_id], references: [id])

  @@map("disputes")
}

model Transaction {
  id                     String              @id @default(uuid()) @db.Uuid
  booking_id             String?             @db.Uuid
  booking_group_id       String?             @db.Uuid
  user_id                String              @db.Uuid
  amount                 Decimal             @db.Decimal(12, 2)
  type                   TransactionType
  status                 TransactionStatus   @default(PENDING)
  payment_method         PaymentMethod
  gateway_transaction_id String?
  description            String?
  created_at             DateTime            @default(now()) @db.Timestamp(6)
  updated_at             DateTime            @updatedAt
  booking_group          BookingGroup?       @relation(fields: [booking_group_id], references: [id])
  booking                Booking?            @relation(fields: [booking_id], references: [id])
  user                   User                @relation(fields: [user_id], references: [id])
  wallet_ledger_lines    WalletTransaction[]

  @@index([user_id])
  @@index([booking_id])
  @@index([booking_group_id])
  @@index([gateway_transaction_id])
  @@index([status])
  @@map("transactions")
}

model Promotion {
  id                  String           @id @default(uuid()) @db.Uuid
  code                String           @unique
  sponsor_type        PromotionSponsor @default(PLATFORM)
  creator_id          String?          @db.Uuid
  discount_type       PromotionType
  discount_value      Decimal          @db.Decimal(12, 2)
  min_order_value     Decimal?         @db.Decimal(12, 2)
  max_discount_amount Decimal?         @db.Decimal(12, 2)
  start_date          DateTime         @db.Timestamp(6)
  end_date            DateTime         @db.Timestamp(6)
  usage_limit         Int?
  used_count          Int              @default(0)
  is_active           Boolean          @default(true)
  created_at          DateTime         @default(now()) @db.Timestamp(6)
  updated_at          DateTime         @updatedAt
  booking_groups      BookingGroup[]
  bookings            Booking[]
  creator             User?            @relation("PromotionCreator", fields: [creator_id], references: [id])
  applicable_lenses   LensListing[]    @relation("LensToPromotion")

  @@map("promotions")
}

model Review {
  id               String       @id @default(uuid()) @db.Uuid
  reviewer_id      String       @db.Uuid
  booking_id       String       @db.Uuid
  lens_id          String?      @db.Uuid
  reviewed_user_id String?      @db.Uuid
  rating           Int
  comment          String?
  owner_reply      String?
  created_at       DateTime     @default(now()) @db.Timestamp(6)
  booking          Booking      @relation(fields: [booking_id], references: [id])
  lens             LensListing? @relation(fields: [lens_id], references: [id], onDelete: Cascade)
  reviewed_user    User?        @relation("ReviewedUser", fields: [reviewed_user_id], references: [id])
  reviewer         User         @relation("Reviewer", fields: [reviewer_id], references: [id])

  @@unique([booking_id, lens_id])
  @@unique([booking_id, reviewed_user_id])
  @@map("reviews")
}

model BlockedDate {
  id               String      @id @default(uuid()) @db.Uuid
  lens_id          String      @db.Uuid
  blocked_quantity Int         @default(1)
  start_date       DateTime
  end_date         DateTime
  reason           String?
  lens             LensListing @relation(fields: [lens_id], references: [id], onDelete: Cascade)

  @@index([lens_id, start_date, end_date])
  @@map("blocked_dates")
}

model Wallet {
  id                  String              @id @default(uuid()) @db.Uuid
  user_id             String              @unique @db.Uuid
  available_balance   Decimal             @default(0) @db.Decimal(12, 2)
  pending_balance     Decimal             @default(0) @db.Decimal(12, 2)
  created_at          DateTime            @default(now()) @db.Timestamp(6)
  updated_at          DateTime            @updatedAt
  payouts             Payout[]
  wallet_transactions WalletTransaction[]
  user                User                @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("wallets")
}

/// Sổ cái biến động ví — mỗi lần đổi available/pending đều có dòng (append-only, audit).
model WalletTransaction {
  id                       String                @id @default(uuid()) @db.Uuid
  wallet_id                String                @db.Uuid
  booking_id               String?               @db.Uuid
  booking_group_id         String?               @db.Uuid
  reference_transaction_id String?               @db.Uuid
  payout_id                String?               @db.Uuid
  bucket                   WalletBalanceBucket
  direction                WalletLedgerDirection
  amount                   Decimal               @db.Decimal(12, 2)
  available_before         Decimal               @db.Decimal(12, 2)
  available_after          Decimal               @db.Decimal(12, 2)
  pending_before           Decimal               @db.Decimal(12, 2)
  pending_after            Decimal               @db.Decimal(12, 2)
  note                     String?
  idempotency_key          String?               @unique @db.VarChar(255)
  created_at               DateTime              @default(now()) @db.Timestamp(6)
  booking_group            BookingGroup?         @relation(fields: [booking_group_id], references: [id])
  booking                  Booking?              @relation(fields: [booking_id], references: [id])
  payout                   Payout?               @relation(fields: [payout_id], references: [id])
  reference_transaction    Transaction?          @relation(fields: [reference_transaction_id], references: [id])
  wallet                   Wallet                @relation(fields: [wallet_id], references: [id], onDelete: Cascade)

  @@index([wallet_id, created_at])
  @@index([booking_id])
  @@index([payout_id])
  @@map("wallet_transactions")
}

/// Phân bổ tiền cho owner theo từng Booking (sau thanh toán group / tách đơn).
model BookingPayoutAllocation {
  id           String                        @id @default(uuid()) @db.Uuid
  booking_id   String                        @unique @db.Uuid
  owner_id     String                        @db.Uuid
  gross_amount Decimal                       @db.Decimal(12, 2)
  platform_fee Decimal                       @default(0) @db.Decimal(12, 2)
  net_amount   Decimal                       @db.Decimal(12, 2)
  status       BookingPayoutAllocationStatus @default(PENDING)
  created_at   DateTime                      @default(now()) @db.Timestamp(6)
  updated_at   DateTime                      @updatedAt @db.Timestamp(6)
  booking      Booking                       @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  owner        User                          @relation(fields: [owner_id], references: [id])

  @@index([owner_id, status])
  @@map("booking_payout_allocations")
}

/// Yêu cầu rút tiền của owner (admin duyệt / chuyển khoản).
model Payout {
  id                  String              @id @default(uuid()) @db.Uuid
  owner_id            String              @db.Uuid
  wallet_id           String              @db.Uuid
  amount              Decimal             @db.Decimal(12, 2)
  status              PayoutRequestStatus @default(PENDING)
  bank_name           String?             @db.VarChar(255)
  bank_account        String?             @db.VarChar(100)
  bank_owner_name     String?             @db.VarChar(255)
  admin_note          String?
  rejection_reason    String?
  processed_at        DateTime?           @db.Timestamp(6)
  processed_by_id     String?             @db.Uuid
  created_at          DateTime            @default(now()) @db.Timestamp(6)
  updated_at          DateTime            @updatedAt @db.Timestamp(6)
  owner               User                @relation("OwnerPayouts", fields: [owner_id], references: [id])
  processed_by        User?               @relation("AdminProcessedPayouts", fields: [processed_by_id], references: [id])
  wallet              Wallet              @relation(fields: [wallet_id], references: [id])
  wallet_transactions WalletTransaction[]

  @@index([owner_id, status])
  @@index([wallet_id, status])
  @@map("payouts")
}

model Conversation {
  id              String    @id @default(uuid()) @db.Uuid
  renter_id       String    @db.Uuid
  owner_id        String    @db.Uuid
  last_message    String?
  last_message_at DateTime  @default(now())
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  owner           User      @relation("OwnerConv", fields: [owner_id], references: [id])
  renter          User      @relation("RenterConv", fields: [renter_id], references: [id])
  messages        Message[]

  @@unique([renter_id, owner_id])
  @@index([owner_id], map: "idx_conversations_owner_id")
  @@index([renter_id], map: "idx_conversations_renter_id")
  @@index([renter_id, owner_id], map: "idx_conversations_renter_owner")
  @@map("conversations")
}

model Message {
  id              String       @id @default(uuid()) @db.Uuid
  conversation_id String       @db.Uuid
  sender_id       String       @db.Uuid
  content         String
  attachment_url  String?
  is_read         Boolean      @default(false)
  created_at      DateTime     @default(now())
  conversation    Conversation @relation(fields: [conversation_id], references: [id])
  sender          User         @relation("MessageSender", fields: [sender_id], references: [id])

  @@index([conversation_id, created_at])
  @@index([sender_id])
  @@index([conversation_id, created_at], map: "idx_messages_conversation_created")
  @@index([conversation_id], map: "idx_messages_conversation_id")
  @@index([is_read], map: "idx_messages_is_read")
  @@index([sender_id], map: "idx_messages_sender_id")
  @@map("messages")
}

model SystemLog {
  id          String   @id @default(uuid()) @db.Uuid
  actor_id    String?  @db.Uuid
  action      String
  description String
  created_at  DateTime @default(now())

  @@map("system_logs")
}

model Notification {
  id           String           @id @default(uuid()) @db.Uuid
  user_id      String           @db.Uuid
  title        String
  content      String
  is_read      Boolean          @default(false)
  created_at   DateTime         @default(now())
  type         NotificationType @default(SYSTEM)
  reference_id String?          @db.Uuid
  user         User             @relation(fields: [user_id], references: [id])

  @@index([user_id, is_read])
  @@map("notifications")
}

enum PromotionSponsor {
  PLATFORM
  OWNER
}

enum BookingGroupStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
  PARTIALLY_PAID
  REFUNDED
}

enum NotificationType {
  SYSTEM
  BOOKING
  MESSAGE
  PROMOTION
}

enum Role {
  USER
  OWNER
  ADMIN
}

enum AccountStatus {
  ACTIVE
  LOCKED
}

enum AuthProvider {
  LOCAL
  GOOGLE
  FACEBOOK
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  ACTIVE
  COMPLETED
  CANCELLED
  REJECTED
  OVERDUE
}

enum DeliveryMethod {
  SELF_PICKUP
  DELIVERY
}

enum DisputeStatus {
  PENDING
  PROCESSING
  RESOLVED
  REJECTED
}

enum TransactionType {
  DEPOSIT
  RENTAL_FEE
  REFUND
  COMMISSION
  PAYOUT
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
  CANCELLED
}

/// Bucket ví bị ảnh hưởng bởi dòng sổ cái (khớp available_balance / pending_balance).
enum WalletBalanceBucket {
  AVAILABLE
  PENDING
}

enum WalletLedgerDirection {
  CREDIT
  DEBIT
}

/// Phân bổ doanh thu owner theo từng Booking.
enum BookingPayoutAllocationStatus {
  PENDING
  AVAILABLE
  PAID
}

/// Lệnh rút tiền owner về ngân hàng.
enum PayoutRequestStatus {
  PENDING
  PROCESSING
  COMPLETED
  REJECTED
}

enum PaymentMethod {
  CASH
  VNPAY
  MOMO
  BANK_TRANSFER
}

enum PromotionType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum ExtensionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DepositType {
  MONEY_PLATFORM
  MONEY_DIRECT
  PAPERWORK
}
